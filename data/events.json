[
  {
	"id": "event_001",
	"name": "背叛的朋友",
	"trigger_condition": {"type": "random", "chance": 0.1, "min_day": 3},
	"text": "你曾经的朋友，如今站在了你的对立面。他或许是被收买，或许是被威胁——但这不重要了。\n\n'你不会真的下手吧？'他颤抖着问。",
	"choices": [
	  {"text": "动手——这是摄政王的命令", "outcome": {"consume_card": "LUST", "evil": 1}},
	  {"text": "放过他——我做不到", "outcome": {"good": 1, "relation_loss": "friend"}}
	],
	"priority": 3,
	"one_time": true
  },
  {
	"id": "event_002",
	"name": "等死的奴隶",
	"trigger_condition": {"type": "random", "chance": 0.15, "min_day": 1},
	"text": "一个濒死的奴隶躺在路边。他的身体已被疾病侵蚀，眼神中只剩下乞求。\n\n'请……请结束我的痛苦。'他虚弱地说。",
	"choices": [
	  {"text": "让他的身体抵债——拖入灵光一现", "outcome": {"consume_card": "MURDER", "evil": 1, "insight_trigger": true}, "requires_card": "MURDER"},
	  {"text": "给他食物和水——我们不是怪物", "outcome": {"good": 1, "gold": -1}},
	  {"text": "无视他——这不是我的问题", "outcome": {}}
	],
	"priority": 3,
	"one_time": true
  },
